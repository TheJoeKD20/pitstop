# Copy this file to `.secrets` (which is gitignored) and fill in real values.
# Pitstop injects every KEY here as an environment variable inside the container
# when you run a job, so a breakpoint shell sees the same secrets your step would.
#
# Format: KEY=value, one per line. Blank lines and # comments are ignored.
# Quote values that contain spaces. Inline # comments are stripped from
# unquoted values.

# Example: a token your CI script reads from the environment.
GITHUB_TOKEN=ghp_replace_me

# Example: a quoted value with spaces.
DEPLOY_MESSAGE="shipped from the pit"

# Example: anything your scripts expect.
NPM_TOKEN=npm_replace_me
